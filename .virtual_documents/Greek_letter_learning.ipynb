class ImageDatasetInference(Dataset):
    def __init__(self, X, transform=None):
        self.X = X # Expecting numpy array of images (H, W)
        self.transform = transform

    def __len__(self):
        return len(self.X)

    def __getitem__(self, idx):
        image = self.X[idx]
        # Convert numpy array (H, W) to PIL Image (H, W) expected by transforms
        image = Image.fromarray((image * 255).astype(np.uint8)) # Explicitly grayscale

        if self.transform:
            image = self.transform(image) # transform includes ToTensor and Normalize

        return image # Return the tensor

