# We need to align the columns (predicted clusters) with the rows (true labels)
# based on the optimal assignment from the Hungarian algorithm for a more
# interpretable confusion matrix for clustering evaluation.
# We can reorder the columns of the confusion matrix based on the `col_ind`
# from the Hungarian algorithm.

# Get the unique true labels (encoded) and cluster labels
true_labels_unique_encoded = np.unique(ground_truth_labels_encoded)
cluster_labels_unique = np.unique(clusters)

# Create a mapping from predicted cluster index to the optimally matched true label index
# This assumes the order of `true_labels_unique_encoded` and `cluster_labels_unique`
# corresponds to the row and column indices of the confusion matrix `cm`.
# Check the shape of cm and the lengths of unique labels to confirm.
if cm.shape[0] == len(true_labels_unique_encoded) and cm.shape[1] == len(cluster_labels_unique):
  # Create a new confusion matrix with columns reordered based on the optimal assignment
  cm_reordered = cm[:, col_ind]

  # Create labels for the reordered columns. The column label should be the cluster ID
  # optimally assigned to the true label represented by that row.
  # The true label for row `i` is `true_labels_unique_encoded[i]`. The cluster optimally
  # assigned to this true label (row `i`) is `cluster_labels_unique[col_ind[i]]`.
  # So the reordered column `j` (which corresponds to `cluster_labels_unique[col_ind[j]]`)
  # is optimally matched with the true label `true_labels_unique_encoded[row_ind[j]]`.
  # A simpler way for visualization is to just label the columns with the cluster ID,
  # but acknowledge they are reordered to align with the true labels.
  # However, for a more informative visualization, we can map the cluster ID
  # to the dominant true label within that cluster based on the Hungarian assignment.

  # Let's create a mapping from the predicted cluster ID to the true label it was mapped to
  # Convert encoded true labels back to original letter names for the map
  encoded_to_letter_map = {i: label for i, label in enumerate(label_encoder_clustering.classes_)}
  cluster_to_true_label_map = {cluster_labels_unique[col_ind[i]]: encoded_to_letter_map[true_labels_unique_encoded[row_ind[i]]] for i in range(len(row_ind))}

  # Create labels for the reordered columns, showing the cluster ID and its matched true label
  reordered_cluster_labels = [f'Cluster {cluster_labels_unique[col_ind[j]]} (Matched to: {encoded_to_letter_map[true_labels_unique_encoded[row_ind[j]]]})' for j in range(cm_reordered.shape[1])]

  # Use the original true label names for the row labels
  true_label_names = label_encoder_clustering.classes_.tolist()
  # Ensure the order of true_label_names matches the order of rows in cm (which corresponds to true_labels_unique_encoded)
  true_label_names_ordered = [encoded_to_letter_map[i] for i in true_labels_unique_encoded]


  sns.heatmap(cm_reordered, annot=True, fmt='d', cmap='Blues',
              xticklabels=reordered_cluster_labels, yticklabels=true_label_names_ordered)
  plt.xlabel('Predicted Cluster (Optimally Matched to True Label)')
  plt.ylabel('True Label')
  plt.title('Confusion Matrix for Clustering Evaluation (Columns Reordered by Hungarian Assignment)')
  plt.tight_layout()
  plt.show()
else:
