from sklearn.metrics import confusion_matrix
from scipy.optimize import linear_sum_assignment
from sklearn.preprocessing import LabelEncoder # Import LabelEncoder
import numpy as np # Import numpy

def hungarian_accuracy(ground_truth, predictions):
  """
    Computes the Hungarian accuracy for clustering.

    Parameters:
    ground_truth (array-like): True labels (numeric).
    predictions (array-like): Predicted cluster labels (numeric).

    Returns:
    float: Hungarian accuracy.
  """
  # Compute the confusion matrix
  # Ensure both inputs are numpy arrays for consistent indexing
  ground_truth = np.asarray(ground_truth)
  predictions = np.asarray(predictions)

  # Compute the confusion matrix
  cm = confusion_matrix(ground_truth, predictions)

  # Handle cases where ground truth labels might not have a one-to-one mapping
  # to cluster labels. Create a cost matrix for the Hungarian algorithm.
  # The cost matrix will represent how many samples from each true class
  # are assigned to each cluster. We want to maximize the number of correctly
  # assigned samples, which is equivalent to minimizing the negative count.
  cost_matrix = -cm

  # Apply the Hungarian algorithm (linear sum assignment) to find the optimal mapping
  # between true classes and clusters that maximizes the sum of counts.
  row_ind, col_ind = linear_sum_assignment(cost_matrix)

  # The optimal assignment gives the maximum number of correctly assigned samples
  # by summing the counts at the chosen indices in the confusion matrix.
  optimal_assignment_sum = -cost_matrix[row_ind, col_ind].sum()

  # The total number of samples is the sum of all entries in the confusion matrix.
  total_samples = cm.sum()

  # Hungarian accuracy is the sum of correctly assigned samples divided by the total samples.
  accuracy = optimal_assignment_sum / total_samples

  return accuracy

# Ground truth labels (e.g., based on the letter)
# ground_truth_labels = data['letter'].values # Original string labels

