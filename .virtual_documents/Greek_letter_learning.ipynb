# prompt: for each letter, perform k-means clustering on its images, testing k from 2 to 5 and selecting the K that yields the best silhouette

# Dictionary to store best k and silhouette score for each letter
best_k_results = {}

# Get unique letters
unique_letters = data['letter'].unique()

# Iterate through each letter
for letter in unique_letters:
    print(f"\nProcessing letter: {letter}")

    # Filter data and image_data_pca for the current letter
    letter_indices = data[data['letter'] == letter].index
    if len(letter_indices) < 2:
        print(f"  Skipping letter '{letter}' - not enough samples for clustering (need at least 2).")
        continue

    letter_image_data_pca = image_data_pca[letter_indices]

    best_silhouette = -1 # Initialize with a low value
    best_k_for_letter = None

    # Test k from 2 to 5
    for k in range(2, 6):
        if k > len(letter_image_data_pca):
            print(f"  Skipping k={k} for letter '{letter}' - more clusters than samples.")
            continue

        print(f"  Testing k = {k} for letter '{letter}'...")
        kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)
        clusters = kmeans.fit_predict(letter_image_data_pca)

        # Calculate silhouette score
        try:
            silhouette_avg = silhouette_score(letter_image_data_pca, clusters)
            print(f"    Silhouette Score for k={k}: {silhouette_avg:.4f}")

            # Check if this is the best silhouette score so far for this letter
            if silhouette_avg > best_silhouette:
                best_silhouette = silhouette_avg
                best_k_for_letter = k

        except Exception as e:
            print(f"    Could not calculate silhouette score for k={k}: {e}")
            continue # Move to the next k

    # Store the best k and silhouette score for the letter
    if best_k_for_letter is not None:
        best_k_results[letter] = {'best_k': best_k_for_letter, 'silhouette_score': best_silhouette}
        print(f"  Best k for letter '{letter}': {best_k_for_letter} (Silhouette: {best_silhouette:.4f})")
    else:
         print(f"  No valid k found for letter '{letter}'.")

# Print the summary of best k and silhouette scores for each letter
print("\n--- Best K and Silhouette Scores per Letter ---")
for letter, result in best_k_results.items():
    print(f"Letter '{letter}': Best K = {result['best_k']}, Silhouette Score = {result['silhouette_score']:.4f}")





from scipy.linalg import orthogonal_procrustes
import cv2

def align_images_procrustes(image_path1, image_path2, size=(64, 64)):
    # Preprocess images to get flattened pixel data
    img1_data = preprocess_image(image_path1, size=size)
    img2_data = preprocess_image(image_path2, size=size)

    # Reshape data to (n_points, n_dimensions) - here n_points is the number of pixels
    # and n_dimensions is 1 for grayscale. For simplicity, we can treat each pixel as a point
    # and use its intensity as a "coordinate". However, Procrustes typically works on point sets.
    # A more appropriate use for Procrustes here would be if we had extracted keypoints
    # from the images.

    # As a simple demonstration using the flattened pixel data as if they were points:
    # This isn't a true Procrustes alignment of shapes, but aligns the "vectors" of pixel values.
    # This might not produce visually meaningful alignment of the shapes themselves.

    # For a true Procrustes shape alignment, you'd need to extract features (like contours or keypoints).
    # Let's assume, for the sake of showing Procrustes, that our flattened image data
    # represents 'points' in a high-dimensional space, and we want to align the sets of points.
    # This is a bit of a stretch for visual alignment of the letter shapes.

    # Let's try a different approach more suited to aligning shapes:
    # Find contours or keypoints and then use Procrustes on those.
    # We'll use OpenCV for contour finding.

    try:
        # Read images in grayscale for contour finding
        img1 = cv2.imread(image_path1, cv2.IMREAD_GRAYSCALE)
        img2 = cv2.imread(image_path2, cv2.IMREAD_GRAYSCALE)

        # Resize for consistency
        img1_resized = cv2.resize(img1, size)
        img2_resized = cv2.resize(img2, size)

        # Threshold images to get binary masks (assuming letters are dark on light background or vice-versa)
        # Adjust thresholding method based on your image characteristics
        _, thresh1 = cv2.threshold(img1_resized, 128, 255, cv2.THRESH_BINARY_INV | cv2.THRESH_OTSU)
        _, thresh2 = cv2.threshold(img2_resized, 128, 255, cv2.THRESH_BINARY_INV | cv2.THRESH_OTSU)


        # Find contours
        contours1, _ = cv2.findContours(thresh1, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
        contours2, _ = cv2.findContours(thresh2, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

        # Select the largest contour (likely the letter)
        contour1 = max(contours1, key=cv2.contourArea) if contours1 else None
        contour2 = max(contours2, key=cv2.contourArea) if contours2 else None

        if contour1 is None or contour2 is None:
            print("Could not find contours in one or both images.")
            return None, None, None # Return None if alignment fails

        # Simplify contours or sample points from them
        # Let's sample a fixed number of points from the contours
        n_points = 100 # Number of points to sample
        points1 = []
        points2 = []

        # Sample points from contour1
        for i in range(n_points):
            t = i / (n_points - 1) * cv2.arcLength(contour1, True)
            pt = cv2.getAffineTransform(np.float32([[0,0],[1,0],[0,1]]), np.float32([[0,0],[1,0],[0,1]])) # Dummy call to get point
            _, pt = cv2.getRotationMatrix2D((0,0),0,1)[0:2,:].dot(np.append(cv2.approxPolyDP(contour1, 1, True)[i % len(cv2.approxPolyDP(contour1, 1, True))][0], 1)) # Incorrect way to sample, need a better method
            # A simpler way is to just use the contour points directly if they are roughly equal number, or resample/interpolate.
            # For demonstration, let's just use the contour points, assuming a reasonable number or that we can truncate/pad.
            # A more robust approach would involve resampling along the arc length.

        # A better approach: Resample points evenly along the contour
        def resample_contour(contour, num_points):
            arc_length = cv2.arcLength(contour, True)
            points = []
            for i in range(num_points):
                t = i / (num_points - 1) * arc_length
                # Find the point along the contour at arc length t - This requires more complex interpolation or using a library.
                # For simplicity, let's just use a subset of the existing points or resample by index.
                # Let's try using a simple index based sampling for now:
                index = int((i / (num_points - 1)) * len(contour)) % len(contour)
                points.append(contour[index][0]) # contour is list of points, each is a list [[x, y]]
            return np.array(points, dtype=np.float32)

        # Resample points from both contours to have the same number
        try:
             points1 = resample_contour(contour1, n_points)
             points2 = resample_contour(contour2, n_points)
        except Exception as e:
             print(f"Error resampling contours: {e}")
             # If resampling fails, try using raw contour points (if sizes are somewhat similar)
             min_len = min(len(contour1), len(contour2))
             points1 = np.array([pt[0] for pt in contour1[:min_len]], dtype=np.float64)
             points2 = np.array([pt[0] for pt in contour2[:min_len]], dtype=np.float64)
             if min_len == 0:
                 print("Contours are empty after resampling attempt.")
                 return None, None, None


        # Perform Orthogonal Procrustes analysis
        # X is the target (points1), Y is the source (points2)
        # We want to find the transformation (rotation and translation) that maps Y onto X
        try:
            R, s = orthogonal_procrustes(points1, points2)

            # Calculate translation - align centroids
            centroid1 = np.mean(points1, axis=0)
            centroid2 = np.mean(points2, axis=0)
            translation = centroid1 - s * centroid2.dot(R.T) # Correct translation calculation

            # Apply transformation to points2
            aligned_points2 = s * points2.dot(R.T) + translation
        except ValueError as e:
             print(f"Orthogonal Procrustes failed: {e}")
             print(f"Shape of points1: {points1.shape}")
             print(f"Shape of points2: {points2.shape}")
             return None, None, None # Return None if Procrustes fails


        # Visualize the original and aligned points
        plt.figure(figsize=(10, 5))

        plt.subplot(1, 2, 1)
        plt.scatter(points1[:, 0], points1[:, 1], label='Rho (Original)', alpha=0.6)
        plt.scatter(points2[:, 0], points2[:, 1], label='Iota (Original)', alpha=0.6)
        plt.title('Original Contour Points')
        plt.xlabel('X')
        plt.ylabel('Y')
        plt.legend()
        plt.gca().invert_yaxis() # Invert Y-axis to match image coordinates

        plt.subplot(1, 2, 2)
        plt.scatter(points1[:, 0], points1[:, 1], label='Rho (Target)', alpha=0.6)
        plt.scatter(aligned_points2[:, 0], aligned_points2[:, 1], label='Iota (Aligned)', alpha=0.6)
        plt.title('Aligned Contour Points (Iota to Rho)')
        plt.xlabel('X')
        plt.ylabel('Y')
        plt.legend()
        plt.gca().invert_yaxis() # Invert Y-axis to match image coordinates

        plt.tight_layout()
        plt.show()

        return R, translation, s # Return rotation matrix, translation vector, and scale factor

    except Exception as e:
        print(f"Error during image alignment: {e}")
        return None, None, None # Return None if alignment fails

# Find the paths for a 'Rho' image and an 'Iota' image
rho_image_path = None
iota_image_path = None

# Assuming 'merged_data' DataFrame contains 'filename' and 'letter' columns
